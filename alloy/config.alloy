// Coleta métricas do simulador
prometheus.scrape "simulator_metrics" {
    targets = [
        {"__address__" = "prom-http-simulator:8080"},
    ]

    // Encaminha as métricas para o Prometheus
    forward_to = [prometheus.remote_write.local_prom.receiver]
    scrape_interval = "15s"
}

// Envia as métricas para o Prometheus utilizando o protocolo Remote Write
prometheus.remote_write "local_prom" {
    endpoint {
        url = "http://prometheus:9090/api/v1/write"
    }
}